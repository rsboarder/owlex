{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AUDIT-0 seeded corpus manifest",
  "description": "Ground-truth-labeled synthetic diffs. Enforced programmatically by bench.scorer.validate_manifest (kept dependency-free — this file is the human-readable contract; the validator is the executable one). Items may carry optional stratification fields (source, lang, diff_size, risk_domain, difficulty, split, provenance) validated by validate_manifest when present; absent fields are never an error.",
  "type": "object",
  "required": ["items"],
  "properties": {
    "schema_version": {"type": "integer"},
    "description": {"type": "string"},
    "line_window_default": {"type": "integer", "minimum": 0},
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "file", "diff_path", "prose_summary", "bugs"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "file": {"type": "string", "minLength": 1},
          "diff_path": {"type": "string", "minLength": 1},
          "prose_summary": {"type": "string", "minLength": 1},
          "bugs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["bug_type", "file", "line", "description"],
              "properties": {
                "bug_type": {"type": "string", "minLength": 1},
                "file": {"type": "string", "minLength": 1},
                "line": {"type": "integer", "minimum": 1},
                "description": {"type": "string", "minLength": 1}
              }
            }
          },
          "decoys": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["file", "line", "description"],
              "properties": {
                "file": {"type": "string", "minLength": 1},
                "line": {"type": "integer", "minimum": 1},
                "description": {"type": "string", "minLength": 1}
              }
            }
          },
          "source": {
            "type": "string",
            "minLength": 1,
            "description": "Origin of this item (e.g. 'seeded', 'real', 'synthetic'). Optional."
          },
          "lang": {
            "type": "string",
            "minLength": 1,
            "description": "Primary programming language of the diff (e.g. 'python'). Optional."
          },
          "risk_domain": {
            "type": "string",
            "minLength": 1,
            "description": "The functional area the bug targets (e.g. 'subprocess', 'config', 'parsing'). Optional."
          },
          "difficulty": {
            "type": "string",
            "minLength": 1,
            "description": "Subjective difficulty for a reviewer to find the bug ('easy', 'medium', 'hard'). Optional."
          },
          "diff_size": {
            "type": "string",
            "enum": ["S", "M", "L"],
            "description": "Rough size of the diff: S=small single-hunk, M=medium, L=large/multi-hunk. Optional."
          },
          "split": {
            "type": "string",
            "enum": ["iterate", "holdout"],
            "description": "Dataset split: 'iterate' for tuning/development, 'holdout' for held-out evaluation. Optional."
          },
          "provenance": {
            "type": "object",
            "description": "Optional traceability record for this item.",
            "properties": {
              "source": {"type": "string"},
              "date": {"type": "string"},
              "ref": {"type": "string"}
            }
          }
        }
      }
    }
  },
  "x-corpus-invariants": {
    "min_bugs": 10,
    "min_bug_types": 3,
    "min_decoys": 2,
    "note": "Enforced by bench.scorer.validate_manifest, not by this JSON Schema."
  }
}
